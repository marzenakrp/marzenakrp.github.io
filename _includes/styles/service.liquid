{%- comment -%}
  Shared styles for the Service page (used by EN/PL/JA versions).
{%- endcomment -%}
<style>
  .service-page {
    margin-top: 0.5rem;
  }

  .service-year {
    margin-bottom: 1.5rem;
  }

  .service-year h2 {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--global-theme-color);
    margin-bottom: 0.6rem;
    padding-bottom: 0.3rem;
    border-bottom: 2px solid var(--global-divider-color);
  }

  .service-items {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .service-row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .service-venue {
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--global-text-color);
    min-width: 140px;
  }

  .service-venue small {
    font-weight: 400;
    font-size: 0.8rem;
    color: var(--global-text-color-light, #666);
  }

  .service-role {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    padding: 0.22em 0.75em;
    border-radius: 999px;
    line-height: 1.35;
  }

  .role-reviewer {
    background: #f1f5f9;
    color: #475569;
    border: 1px solid #cbd5e1;
  }

  .role-ac {
    background: #dbeafe;
    color: #1e40af;
    border: 1px solid #93c5fd;
  }

  .role-sac {
    background: #ede9fe;
    color: #5b21b6;
    border: 1px solid #c4b5fd;
  }

  .role-ethics {
    background: #d1fae5;
    color: #065f46;
    border: 1px solid #6ee7b7;
  }

  .role-grant {
    background: #fef3c7;
    color: #92400e;
    border: 1px solid #fcd34d;
  }

  .service-award {
    display: inline-flex;
    align-items: center;
    gap: 0.3em;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    padding: 0.22em 0.75em;
    border-radius: 999px;
    line-height: 1.35;
    background: linear-gradient(135deg, #fef9c3, #fde68a);
    color: #854d0e;
    border: 1px solid #f59e0b;
    box-shadow: 0 1px 3px rgba(245, 158, 11, 0.2);
  }

  .service-award::before {
    content: '\1F3C6';
    font-size: 0.85em;
  }

  html[data-theme='dark'] .role-reviewer {
    background: #334155;
    color: #e2e8f0;
    border-color: #475569;
  }

  html[data-theme='dark'] .role-ac {
    background: #1e3a5f;
    color: #93c5fd;
    border-color: #3b82f6;
  }

  html[data-theme='dark'] .role-sac {
    background: #2e1065;
    color: #c4b5fd;
    border-color: #7c3aed;
  }

  html[data-theme='dark'] .role-ethics {
    background: #064e3b;
    color: #6ee7b7;
    border-color: #059669;
  }

  html[data-theme='dark'] .role-grant {
    background: #78350f;
    color: #fcd34d;
    border-color: #d97706;
  }

  html[data-theme='dark'] .service-award {
    background: linear-gradient(135deg, #78350f, #92400e);
    color: #fde68a;
    border-color: #d97706;
    box-shadow: 0 1px 3px rgba(217, 119, 6, 0.3);
  }

  @media (max-width: 576px) {
    .service-venue {
      min-width: auto;
      width: 100%;
    }
  }
</style>
